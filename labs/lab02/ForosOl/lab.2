#include <iostream>

class Container {
public:
   
    virtual ~Container() {}

   virtual void push(int value) = 0;
    virtual int pop() = 0;
    virtual size_t size() const = 0;

    friend std::ostream& operator<<(std::ostream& os, const Container& obj) {
        obj.print(os);
        return os;
    }

    friend std::istream& operator>>(std::istream& is, Container& obj) {
        obj.read(is);
        return is;
    }

protected:
    
    virtual void print(std::ostream& os) const = 0;
    virtual void read(std::istream& is) = 0;
};

class MyList : public Container {
private:
    int data[100]; 
    size_t count = 0;

public:
    void push(int value) override {
        if (count < 100) data[count++] = value;
    }

    int pop() override {
        return (count > 0) ? data[--count] : -1;
    }

    size_t size() const override {
        return count;
    }

protected:
    void print(std::ostream& os) const override {
        for (size_t i = 0; i < count; ++i) os << data[i] << " ";
    }

    void read(std::istream& is) override {
        int val;
        is >> val;
        push(val);
    }
};

int main() {
    MyList list;

    list.push(10);
    list.push(20);
    list.push(30);

   std::cout << "Container content: " << list << std::endl;
    std::cout << "Size: " << list.size() << std::endl;

    int popped = list.pop();
    std::cout << "Popped value: " << popped << std::endl;
    std::cout << "New content: " << list << std::endl;

    return 0;
}
